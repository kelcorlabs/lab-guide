### Step 5: Add constrained tool replacement

Replace a generic `fetch_url` (accepts any URL) with a constrained `load_document` (validates against an approved domain list). The generic version accepts `evil-site.com/malware.exe` without complaint. The constrained version rejects it before fetching.

```python
# ============================================================
# PART 3: CONSTRAINED TOOL REPLACEMENT
# ============================================================

# -- Step 5: Generic vs constrained tools --------------------------------

APPROVED_DOMAINS = [
    "docs.internal.com", "arxiv.org", "reports.internal.com"
]


def fetch_url(url):
    """UNSAFE: Generic fetch -- accepts any URL, no validation.
    An agent could call this on any website, API, or internal service.
    """
    return {
        "tool": "fetch_url",
        "url": url,
        "status": "fetched",
        "warning": "No domain validation -- accepted anything"
    }


def load_document(doc_url):
    """SAFE: Constrained replacement -- only approved document domains.
    Validates the URL before fetching. Rejects anything outside
    the approved list.
    """
    domain_match = False
    for domain in APPROVED_DOMAINS:
        if domain in doc_url:
            domain_match = True
            break

    if not domain_match:
        return {
            "tool": "load_document",
            "url": doc_url,
            "status": "rejected",
            "error": f"Domain not in approved list: "
                     f"{APPROVED_DOMAINS}",
            "isError": True,
            "errorCategory": "access",
            "isRetryable": False,
        }

    return {
        "tool": "load_document",
        "url": doc_url,
        "status": "loaded",
        "domain_validated": True,
        "content": f"[Simulated document content from {doc_url}]"
    }


def run_demo_constrained_replacement():
    """Demo 3: Replace generic tools with constrained alternatives."""
    sep = "=" * 60
    print(f"\n{sep}")
    print("DEMO 3: CONSTRAINED TOOL REPLACEMENT")
    print(sep)

    test_urls = [
        ("docs.internal.com/invoices/1042.pdf", "approved"),
        ("arxiv.org/abs/2401.12345", "approved"),
        ("evil-site.com/malware.exe", "unapproved"),
        ("api.internal.com/admin/delete-all", "unapproved"),
    ]

    print("\n  --- fetch_url (UNSAFE: no validation) ---")
    for url, note in test_urls:
        result = fetch_url(url)
        print(f"  {url}")
        print(f"    -> status: {result['status']}  ({note})")

    print(f"\n  --- load_document (SAFE: domain validation) ---")
    for url, note in test_urls:
        result = load_document(url)
        print(f"  {url}")
        if result["status"] == "loaded":
            print(f"    -> status: loaded  "
                  f"(validated: {result['domain_validated']})")
        else:
            print(f"    -> status: REJECTED")
            print(f"       error: {result['error']}")
```


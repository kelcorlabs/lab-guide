def cross_file_analysis(per_file_results):
    """Cross-file integration pass (final step in the chain).
    In production: client.messages.create() with all findings.
    """
    return [
        {"files": ["auth.py", "api.py"],
         "issue": "api.py imports verify_token but doesn't "
                  "handle its failure modes",
         "severity": "high"},
        {"files": ["auth.py"],
         "issue": "Secret 'secret123' is hardcoded -- "
                  "use environment variable",
         "severity": "high"},
    ]


def run_prompt_chaining(files):
    """Fixed pipeline: per-file analysis -> cross-file pass."""
    print("=" * 60)
    print("PATTERN 1: Prompt Chaining (fixed pipeline)")
    print("=" * 60)

    # Step 1: Per-file local analysis
    print("\n--- Step 1: Per-file analysis ---")
    per_file = {}
    for filename, content in files.items():
        findings = analyze_file(filename, content)
        per_file[filename] = findings
        print(f"    {filename}: {len(findings)} issues found")
        for f in findings:
            print(f"      [{f['severity'].upper()}] "
                  f"line {f['line']}: {f['issue'][:50]}...")

    # Step 2: Cross-file integration pass
    print("\n--- Step 2: Cross-file integration ---")
    integration = cross_file_analysis(per_file)
    for f in integration:
        print(f"    [{f['severity'].upper()}] "
              f"{' + '.join(f['files'])}: "
              f"{f['issue'][:50]}...")

    total = sum(len(v) for v in per_file.values()) + len(integration)
    print(f"\n    Total: {total} issues "
          f"({sum(len(v) for v in per_file.values())} local "
          f"+ {len(integration)} cross-file)")

    return {"per_file": per_file, "integration": integration}



    print(f"COORDINATOR: {query}")
    print(f"{'=' * 60}")

    # ---- STEP 1: Select subagents ----
    query_lower = query.lower()
    needs_search = any(w in query_lower for w in
                       ["market", "trend", "research", "data"])
    needs_analysis = any(w in query_lower for w in
                         ["document", "report", "internal", "analyze"])

    # For broad queries, use both
    if "comprehensive" in query_lower or "full" in query_lower:
        needs_search = True
        needs_analysis = True


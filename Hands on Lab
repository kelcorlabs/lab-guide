### Step 2: Add the tool_choice simulator and downstream parser

The simulator models Claude's behavior under each `tool_choice` setting. The parser is the downstream system that crashes when it gets text instead of a tool call -- this is the bug that `tool_choice` fixes.

```python
# -- Step 2: Simulate tool_choice behavior --------------------------------

def simulate_tool_choice(tool_choice, document):
    """Simulate Claude's response under different tool_choice settings.
    Returns a dict matching the Messages API response structure.
    """
    if tool_choice == "auto":
        # With "auto", Claude sometimes returns text instead of calling
        # a tool. In production this happens 10-40% of the time depending
        # on the query. This simulation returns text to show the failure.
        return {
            "stop_reason": "end_turn",
            "content": [
                {"type": "text",
                 "text": "This is an invoice from Acme Corp dated "
                         "2024-03-15 for $189.00 total."}
            ]
        }

    elif tool_choice == "any":
        # With "any", Claude MUST call a tool -- guaranteed.
        # It picks the best-matching tool from the available list.
        return {
            "stop_reason": "tool_use",
            "content": [
                {"type": "tool_use",
                 "name": "extract_invoice",
                 "input": {"document": document}}
            ]
        }

    elif isinstance(tool_choice, dict) and tool_choice.get("type") == "tool":
        # Forced: Claude MUST call this specific named tool.
        forced_name = tool_choice["name"]
        return {
            "stop_reason": "tool_use",
            "content": [
                {"type": "tool_use",
                 "name": forced_name,
                 "input": {"document": document}}
            ]
        }

    return {"error": f"Unknown tool_choice: {tool_choice}"}


def parse_extraction_result(response):
    """Downstream parser that expects a tool call.
    Crashes on text responses -- this is the bug tool_choice fixes.
    """
    if response["stop_reason"] == "end_turn":
        return {
            "success": False,
            "error": "Parser expected tool_use, got text. "
                     "Pipeline crashed."
        }

    for block in response["content"]:
        if block.get("type") == "tool_use":
            return {
                "success": True,
                "tool_called": block["name"],
                "input_received": True
            }

    return {"success": False, "error": "No tool_use block found"}
```


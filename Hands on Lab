            result = {"isError": False,
                      "id": "CUST-001", "name": "Jane Smith"}
            print(f"  attempt {attempt + 1}: "
                  f"success -- {result['name']}")
        if (result.get("isError")
                and result.get("isRetryable")
                and attempt < max_retries):
            continue
        break
    if not result.get("isError"):
        print("  -> coordinator never involved")


def demo_business_propagation():
    """
    Outcome 2: non-retryable error propagated immediately.
    isRetryable: False means do not retry -- act on category instead.
    """
    print("\n--- Outcome 2: Business error -> immediate propagation ---")
    result = simulate_tool_call("locked@test.com")
    print(f"  attempt 1: {result['errorCategory']} error"
          f" (isRetryable: {result['isRetryable']})")
    print("  -> propagating immediately (no retry)")
    print(f"  -> message for user: "
          f"{result['customer_friendly_message']}")


def demo_exhausted_retries():
    """
    Outcome 3: transient error persists through all local retries.
    Subagent propagates with context so coordinator can decide.
    """
    print("\n--- Outcome 3: Transient persists -> propagate ---")
    max_retries = 1
    last_result = None
    for attempt in range(max_retries + 1):
        last_result = make_transient_error("get_customer")
        if attempt < max_retries:
            print(f"  attempt {attempt + 1}: transient -- retrying")
        else:
            print(f"  attempt {attempt + 1}: "
                  f"transient -- retries exhausted")
    propagated = {
        "status": "partial_failure",
        "error": last_result,
        "attempts": max_retries + 1,
        "note": "Coordinator should try alternative approach"
    }
    print(f"  -> propagated: {propagated['note']}")

### Step 6: Add the system prompt keyword audit

```python
# -- Step 6: System prompt keyword audit ---------------------------------
# Words that appear in both the system prompt and a tool name bias Claude
# toward that tool -- even when the request does not match.

def audit_system_prompt_for_tool_keywords(system_prompt, tool_names):
    warnings = []
    prompt_words = system_prompt.lower().replace("_", " ").split()
    for tool in tool_names:
        tool_words = tool.lower().replace("_", " ").split()
        for word in tool_words:
            if len(word) > 4 and word in prompt_words:
                warnings.append(
                    f"System prompt contains '{word}' which matches tool '{tool}'"
                )
    return warnings
```


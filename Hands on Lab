### Step 2: Build the cost calculator

```python
# ============================================================
# PART 2: COST CALCULATOR
# ============================================================

INPUT_COST_PER_M = 3.00
OUTPUT_COST_PER_M = 15.00
BATCH_DISCOUNT = 0.50


def calculate_costs(workload):
    """Calculate real-time vs batch costs."""
    count = workload["count"]
    inp = workload["avg_input_tokens"]
    out = workload["avg_output_tokens"]

    total_input = count * inp / 1_000_000
    total_output = count * out / 1_000_000

    realtime = (total_input * INPUT_COST_PER_M
                + total_output * OUTPUT_COST_PER_M)
    batch = realtime * BATCH_DISCOUNT

    return {
        "realtime_cost": round(realtime, 2),
        "batch_cost": round(batch, 2),
        "savings": round(realtime - batch, 2),
    }


def recommend(workload):
    """Recommend batch vs real-time."""
    costs = calculate_costs(workload)
    latency = workload["latency_requirement"]

    if latency == "none":
        return {
            "recommendation": "BATCH",
            "reason": "No latency requirement -- "
                      "50% savings with batch API",
            **costs,
        }
    return {
        "recommendation": "REAL-TIME",
        "reason": "Latency requirement: " + latency
                  + " -- batch has no SLA",
        **costs,
    }
```


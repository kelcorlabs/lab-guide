def search_agent(query, source):
    """Subagent that returns structured errors."""
    if source == "reuters.com":
        # Simulate rate limit failure
        return {
            "success": False,
            "error": {
                "type": "rate_limit",
                "source": source,
                "query": query,
                "is_retryable": True,
                "partial_results": None,
                "alternatives": [
                    "Try cached version",
                    "Use backup: archive.org",
                    "Proceed without this source",
                ],
            },
        }
    # Success case
    return {
        "success": True,
        "source": source,
        "data": {
            "query": query,
            "findings": [
                f"Market grew 35% in 2023 ({source})",
            ],
        },
    }


def analyze_agent(data):
    """Analyze agent that only processes real data."""
    if not data.get("success", False):
        # Don't analyze errors -- pass through
        return data
    return {
        "success": True,
        "analysis": f"Analyzed {len(data['data']['findings'])} "
                    f"findings from {data['source']}",
        "source": data["source"],
    }

### Step 3: Add coordinator with inspection

```python
# ============================================================
# PART 3: COORDINATOR WITH INSPECTION
# ============================================================

def coordinator_run(query, sources):
    """Coordinator that inspects each subagent result."""
    print("\n" + "=" * 60)
    print("STRUCTURED ERROR PROPAGATION")
    print("=" * 60)

    results = {}
    errors = {}

    # Phase 1: Search all sources
    print("\n  Phase 1: Search")
    for source in sources:
        result = search_agent(query, source)

        if result["success"]:
            print(f"  [OK] {source}: "
                  f"{len(result['data']['findings'])} "
                  f"findings")
            results[source] = result
        else:
            err = result["error"]
            print(f"  [FAIL] {source}: "
                  f"{err['type']}")
            errors[source] = err

            # Try route-around if retryable
            if err["is_retryable"]:
                print(f"    Retryable -- trying "
                      f"alternatives:")
                for alt in err["alternatives"][:1]:
                    print(f"      -> {alt}")

    # Phase 2: Analyze only successful results
    print("\n  Phase 2: Analyze (only successes)")
    analyses = {}
    for source, result in results.items():
        analysis = analyze_agent(result)
        analyses[source] = analysis
        print(f"  [OK] Analyzed: {source}")

    # Phase 3: Synthesize with gap annotations
    print("\n  Phase 3: Synthesize with gaps noted")
    coverage = {
        "sources_available": list(results.keys()),
        "sources_failed": list(errors.keys()),
        "coverage_note": (
            f"{len(results)}/{len(sources)} sources "
            f"available"
        ),
    }
    print(f"  Coverage: {coverage['coverage_note']}")
    if errors:
        for source, err in errors.items():
            print(f"  Gap: {source} -- {err['type']}")

    return {
        "analyses": analyses,
        "errors": errors,
        "coverage": coverage,
    }
```


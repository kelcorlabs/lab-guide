    for app in APPLICATIONS:
        conf = MODEL_CONFIDENCE[app["id"]]
        routed = "REVIEW" if conf < 0.90 else "AUTO"
        flag = ""
        if routed == "AUTO" and (
            app["amount"] > 10000
            or 580 <= app["credit_score"] <= 620
            or not app["income_verified"]
        ):
            flag = " <- MISSED EDGE CASE"
        if routed == "REVIEW" and (
            app["credit_score"] > 700
            and app["amount"] < 10000
            and app["income_verified"]
        ):
            flag = " <- UNNECESSARY REVIEW"
        if routed == "REVIEW":
            conf_reviews += 1
        print(f"  {app['id']}: conf={conf:.2f} "
              f"-> {routed}{flag}")

    # Deterministic routing
    print("\n  --- Deterministic rules ---")
    det_reviews = 0
    for app in APPLICATIONS:
        result = route_application(app)
        if result["action"] == "REVIEW":
            det_reviews += 1
            reasons = ", ".join(
                n for n, _ in result["flags"]
            )
            print(f"  {app['id']}: -> REVIEW "
                  f"({reasons})")
        else:
            print(f"  {app['id']}: -> "
                  f"{result['action']}")

    print(f"\n  Confidence routed {conf_reviews}/5 "
          f"to review")
    print(f"  Deterministic routed {det_reviews}/5 "
          f"to review")
    print(f"  Deterministic catches edge cases that "
          f"confidence misses")

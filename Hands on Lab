def phase1_map_structure():
    """Phase 1: Map codebase structure (discover what's there).
    In production: client.messages.create() analyzing file tree.
    """
    print("\n--- Phase 1: Map structure ---")
    structure = CODEBASE_STRUCTURE["modules"]

    print(f"    Found {len(structure)} modules:")
    for name, info in structure.items():
        callers = len(info["imported_by"])
        print(f"      {name:12s} "
              f"{info['files']:2d} files, "
              f"{callers} callers, "
              f"{info['test_coverage']}% tested")

    return structure


def phase2_identify_high_impact(structure):
    """Phase 2: Identify where effort matters most.
    Uses Phase 1's output to rank modules by impact.
    """
    print("\n--- Phase 2: Identify high-impact areas ---")

    scored = []
    for name, info in structure.items():
        score = 0
        reasons = []

        # Most callers = highest blast radius
        callers = len(info["imported_by"])
        if callers >= 3:
            score += 3
            reasons.append(f"{callers} callers (high blast radius)")

        # Zero or low test coverage = highest risk
        if info["test_coverage"] < 20:
            score += 3
            reasons.append(f"{info['test_coverage']}% coverage "
                           f"(high risk)")

        # Recent bugs = historically unreliable
        if info["recent_bugs"] >= 2:
            score += 2
            reasons.append(f"{info['recent_bugs']} recent bugs")

        # System boundary (imports nothing = leaf, imported by
        # many = boundary)
        if not info["imports_from"] and callers >= 2:
            score += 1
            reasons.append("system boundary")

        scored.append({
            "module": name,
            "score": score,
            "reasons": reasons
        })

    # Sort by score descending
    scored.sort(key=lambda x: x["score"], reverse=True)

    print("    Priority ranking:")
    for i, item in enumerate(scored, 1):
        reason_str = "; ".join(item["reasons"]) if item["reasons"] else "low priority"
        print(f"    {i}. {item['module']:12s} "
              f"(score: {item['score']}) -- {reason_str}")

    return scored


def phase3_create_plan(ranked_areas, structure):
    """Phase 3: Create a prioritized plan that adapts.
    Uses Phase 2's ranking to sequence work, then discovers
    new dependencies that change the plan.
    """
    print("\n--- Phase 3: Prioritized plan ---")

    plan = []
    for item in ranked_areas[:3]:  # Top 3 priorities
        module = item["module"]
        info = structure[module]
        plan.append({
            "priority": len(plan) + 1,
            "module": module,
            "action": f"Add tests (currently "
                      f"{info['test_coverage']}% coverage)",
            "dependencies": info["imports_from"]
        })

    print("    Initial plan:")
    for step in plan:
        deps = ", ".join(step["dependencies"]) if step["dependencies"] else "none"
        print(f"    {step['priority']}. {step['module']:12s} "
              f"-- {step['action']} (depends on: {deps})")

    # Adaptive re-planning: discover something unexpected
    print("\n    [DISCOVERY] While testing payments/, found it "
          "depends on")
    print("    an undocumented currency conversion helper in "
          "utils/.")
    print("    Re-prioritizing: test currency conversion BEFORE "
          "payments/.")

    adapted_plan = [
        {"priority": 1,
         "module": "utils/currency.py",
         "action": "Test currency conversion (discovered dep)",
         "new": True},
    ] + plan

    print("\n    Adapted plan:")
    for i, step in enumerate(adapted_plan, 1):
        marker = " [NEW]" if step.get("new") else ""
        print(f"    {i}. {step['module']:20s} "
              f"-- {step['action']}{marker}")

    return adapted_plan


def run_dynamic_decomposition():
    """Full 3-phase dynamic decomposition pipeline."""
    print(f"\n{'=' * 60}")
    print("PATTERN 2: Dynamic Decomposition (adaptive)")
    print("=" * 60)

    # Each phase's output feeds the next phase
    structure = phase1_map_structure()
    ranked = phase2_identify_high_impact(structure)
    plan = phase3_create_plan(ranked, structure)

    return plan



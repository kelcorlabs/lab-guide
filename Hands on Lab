## Reference code

First, we define the tool schema and a validator that catches semantic errors
(things JSON schema alone can't catch — like line items not summing to total).

```python
import json

# In production, replace with client.messages.create()

extraction_tool = {
    "name": "extract_invoice",
    "description": "Extract invoice data",
    "input_schema": {
        "type": "object",
        "properties": {
            "invoice_number": {"type": "string"},
            "vendor_name": {"type": "string"},
            "total_amount": {"type": ["number", "null"]},
            "line_items": {
                "type": "array",
                "items": {"type": "object",
                          "properties": {"description": {"type": "string"},
                                         "amount": {"type": "number"}},
                          "required": ["description", "amount"]}
            },
            "calculated_total": {"type": ["number", "null"]},
            "conflict_detected": {"type": "boolean"}
        },
        "required": ["invoice_number", "vendor_name", "line_items", "conflict_detected"]
    }
}

def validate_extraction(data: dict) -> list:
    """Returns list of validation error messages."""
    errors = []

    if not data.get("invoice_number"):
        errors.append("invoice_number is empty")

    items = data.get("line_items", [])
    if items:
        calc = sum(item.get("amount", 0) for item in items)
        stated = data.get("total_amount")
        if stated and abs(calc - stated) > 0.01:
            # If there's a mismatch, the model MUST flag it
            if not data.get("conflict_detected"):
                errors.append(
                    f"Line items sum to ${calc:.2f} but total_amount is ${stated:.2f}. "
                    f"Set calculated_total={calc:.2f} and conflict_detected=true."
                )

    return errors
```

## Reference code

This is the core pattern: when validation fails, send a follow-up that includes
the original document + the failed extraction + SPECIFIC error messages.
Claude can self-correct because it knows exactly what went wrong.

```python
def extract_with_retry(doc_text: str, max_retries: int = 2) -> dict:
    """
    Extract invoice data with retry-on-validation-failure.

    KEY PATTERN: Each retry includes the SPECIFIC validation errors.
    "Your previous extraction had these errors: [specific errors]"
    This is far more effective than vague retries.
    In production, replace simulated responses with client.messages.create()
    using tools=[extraction_tool], tool_choice={"type": "tool", "name": "extract_invoice"}
    """
    # Simulated extraction responses per attempt
    if "INV-999" in doc_text:
        # Conflicting totals -- attempt 1 misses conflict, attempt 2 corrects it
        attempt_responses = [
            {  # Attempt 1: misses the conflict
                "invoice_number": "INV-999",
                "vendor_name": "Widget Co",
                "total_amount": 350.00,
                "line_items": [
                    {"description": "Widget A", "amount": 100.00},
                    {"description": "Widget B", "amount": 200.00}
                ],
                "calculated_total": 300.00,
                "conflict_detected": False  # Wrong -- should be True
            },
            {  # Attempt 2: corrected after specific error feedback
                "invoice_number": "INV-999",
                "vendor_name": "Widget Co",
                "total_amount": 350.00,
                "line_items": [
                    {"description": "Widget A", "amount": 100.00},
                    {"description": "Widget B", "amount": 200.00}
                ],
                "calculated_total": 300.00,
                "conflict_detected": True  # Corrected
            }
        ]
    else:
        # Missing data doc -- retries won't help (data isn't there)
        attempt_responses = [
            {
                "invoice_number": "INV-888",
                "vendor_name": "Supply Plus",
                "total_amount": None,  # Correctly null -- data isn't in document
                "line_items": [],
                "calculated_total": None,
                "conflict_detected": False
            }
        ]

    for attempt in range(max_retries + 1):
        print(f"\n  Attempt {attempt + 1}/{max_retries + 1}...")

        # In production, this would be client.messages.create()
        data = attempt_responses[min(attempt, len(attempt_responses) - 1)]

        errors = validate_extraction(data)

        if not errors:
            print(f"  Valid on attempt {attempt + 1}")
            return data

        print(f"  Errors: {errors}")

        if attempt < max_retries:
            # In production, retry with SPECIFIC error feedback:
            error_list = "\n".join(f"- {e}" for e in errors)
            print(f"  Retrying with feedback:\n{error_list}")

    print(f"  Returning best attempt after {max_retries + 1} tries")
    return data
```


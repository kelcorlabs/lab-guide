    ]


# -- PARALLEL SPAWNING -------------------------------------
# In production, multiple Agent tool calls in ONE coordinator
# response = parallel execution. This driver simulates that.

def spawn_subagents_parallel(subagent_calls):
    """Execute multiple subagent calls concurrently.

    In the Agent SDK, this happens when the coordinator emits
    multiple Agent tool_use blocks in a single response.
    Here we simulate it with ThreadPoolExecutor.
    """
    print(f"\n    Spawning {len(subagent_calls)} subagents "
          f"in parallel...")
    start = time.time()

    results = {}
    with ThreadPoolExecutor(max_workers=len(subagent_calls)) as pool:
        futures = {}
        for name, func, query in subagent_calls:
            futures[name] = pool.submit(func, query)

        for name, future in futures.items():
            results[name] = future.result()
            print(f"    [{name}] returned "
                  f"{len(results[name])} findings")

    elapsed = time.time() - start
    print(f"    All subagents completed in {elapsed:.2f}s "
          f"(parallel)")
    return results


def spawn_subagents_sequential(subagent_calls):
    """Execute subagent calls one at a time (for comparison)."""
    print(f"\n    Spawning {len(subagent_calls)} subagents "
          f"sequentially...")
    start = time.time()

    results = {}
    for name, func, query in subagent_calls:
        results[name] = func(query)
        print(f"    [{name}] returned "
              f"{len(results[name])} findings")

    elapsed = time.time() - start
    print(f"    All subagents completed in {elapsed:.2f}s "
          f"(sequential)")
    return results



### Step 2: Build the case facts block

```python
# ============================================================
# PART 2: CASE FACTS BLOCK
# ============================================================

def build_case_facts(facts):
    """Create a persistent facts block that survives
    summarization. Injected at the start of each prompt.
    """
    lines = ["=== CASE FACTS (do not summarize) ==="]
    lines.append("Customer ID:    "
                 + facts.get("customer_id", "unknown"))
    lines.append("Order IDs:      "
                 + ", ".join(facts.get("order_ids", [])))
    lines.append("Order Total:    $"
                 + str(facts.get("total", "N/A")))
    lines.append("Status:         "
                 + facts.get("status", "unknown"))
    lines.append("Issue:          "
                 + facts.get("issue", "not stated"))
    lines.append("Last Action:    "
                 + facts.get("last_action", "none"))
    lines.append("=== END CASE FACTS ===")
    return "\n".join(lines)
```


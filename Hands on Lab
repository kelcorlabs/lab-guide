    print(f"    Search agent:   {'YES' if needs_search else 'no'}")
    print(f"    Analysis agent: {'YES' if needs_analysis else 'no'}")

    # ---- STEP 2: Invoke subagents, collect findings ----
    print(f"\n--- Step 2: Invoke subagents ---")
    all_findings = []

    if needs_search:

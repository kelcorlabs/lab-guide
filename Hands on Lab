    "my-experimental-tool": {
      "command": "python",
      "args": ["/home/me/tools/my_mcp_server.py"]
    }
  }
}
```

This is **user-scoped** -- not shared via git. If you name this server the same as a project server (e.g., `"github"`), the user config wins and shadows the team's setup.

### Step 6: Build the config validator

Create `~/claude-architect-labs/lab-d2-tool-design/mcp_config_validator.py`:

```python
import json
import os
import re


def validate_mcp_config(path, scope_name):
    """Validate an MCP config file for security and correctness."""
    print(f"\n{'=' * 60}")
    print(f"Validating {scope_name}: {path}")
    print("=" * 60)

    if not os.path.exists(path):
        print(f"  [WARNING] File not found -- create it first")
        return []

    with open(path) as f:
        try:
            config = json.load(f)
        except json.JSONDecodeError as e:
            print(f"  [BLOCKED] Invalid JSON: {e}")
            return [f"Invalid JSON in {scope_name}"]

    print(f"  [OK] Valid JSON")
    issues = []

    servers = config.get("mcpServers", {})
    if not servers:
        print(f"  [WARNING] No 'mcpServers' found")
        return ["No servers configured"]

    print(f"  [OK] Found {len(servers)} server(s): "
          f"{', '.join(servers.keys())}")

    for name, server in servers.items():
        # Check 1: Missing command field
        if "command" not in server:
            msg = f"Server '{name}': missing 'command' field"
            issues.append(msg)
            print(f"  [BLOCKED] {msg}")

        # Check 2: Hardcoded secrets
        config_str = json.dumps(server)
        if re.search(r'(ghp_|sk-|token_|gho_|glpat-)'
                     r'[a-zA-Z0-9]{20,}', config_str):
            msg = (f"Server '{name}': HARDCODED SECRET "
                   f"DETECTED -- use ${{ENV_VAR}} instead!")
            issues.append(msg)
            print(f"  [BLOCKED] {msg}")

        # Check 3: Environment variable status
        env_vars = re.findall(r'\$\{(\w+)\}', config_str)
        if env_vars:
            for var in env_vars:
                if os.environ.get(var):
                    print(f"  [OK] Server '{name}': "
                          f"${{{var}}} is set")
                else:
                    msg = (f"Server '{name}': ${{{var}}} "
                           f"is NOT set in environment")
                    issues.append(msg)
                    print(f"  [WARNING] {msg}")
        else:
            if "env" not in server:
                print(f"  [INFO] Server '{name}': "
                      f"No env vars (OK if no credentials)")

        # Check 4: Personal servers in project config
        if scope_name == "Project-scoped":
            personal_indicators = [
                "/home/", "/Users/", "my-", "my_",
                "experimental", "local-", "test-server"
            ]
            for indicator in personal_indicators:
                if indicator in config_str:
                    msg = (f"Server '{name}': looks personal "
                           f"(contains '{indicator}') -- "
                           f"move to ~/.claude.json")
                    issues.append(msg)
                    print(f"  [WARNING] {msg}")
                    break

        if not any(name in i for i in issues):
            print(f"  [OK] Server '{name}': config looks good")

    return issues


def print_scoping_rules():
    """Print the MCP scoping reference."""
    print(f"\n{'=' * 60}")
    print("MCP SCOPING RULES")
    print("=" * 60)
    print("""
  .mcp.json (project root)     Shared via git. All teammates.
  ~/.claude.json (home dir)    Personal only. Not in git.

  BOTH load at startup. If same server name in both,
  user config wins (can accidentally shadow project).

  NEVER hardcode secrets. Use ${ENV_VAR} expansion:
    "env": {"GITHUB_TOKEN": "${GITHUB_TOKEN}"}
  Then: export GITHUB_TOKEN="ghp_xxx" in shell profile.
""")


def print_resources_vs_tools():
    """Print the resources vs tools distinction."""
    print(f"{'=' * 60}")
    print("MCP RESOURCES VS TOOLS")
    print("=" * 60)
    print("""
  Tools:     Actions the agent can take
             search_issues, run_query, create_pr
             -> Change state, cost a round-trip each

  Resources: Read-only content catalogs
             Issue lists, database schemas, doc indexes
             -> Agent sees what's available immediately
             -> Reduces exploratory tool calls

  Example resource:
    {"uri": "docs://api/endpoints",
     "name": "API Endpoint Catalog",
     "description": "REST endpoints with methods and auth"}

  Without resource: agent calls list_endpoints(),
    list_tables(), list_docs() -- 3 discovery calls
  With resource: agent reads catalog, calls specific
    tools only when it needs to act -- 0 discovery calls
""")


if __name__ == "__main__":
    print("MCP Configuration Validator")
    print("=" * 60)

    project_issues = validate_mcp_config(
        ".mcp.json", "Project-scoped"
    )

    home = os.path.expanduser("~")
    user_config = os.path.join(home, ".claude.json")
    user_issues = validate_mcp_config(
        user_config, "User-scoped"
    )

    print_scoping_rules()
    print_resources_vs_tools()

    total = len(project_issues) + len(user_issues)
    print(f"{'=' * 60}")
    print(f"SUMMARY: {total} issue(s) found")
    print("=" * 60)
    if project_issues:
        print("  Project config issues:")
        for i in project_issues:
            print(f"    - {i}")
    if user_issues:
        print("  User config issues:")
        for i in user_issues:
            print(f"    - {i}")
    if total == 0:
        print("  All configs look good!")
```


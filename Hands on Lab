            "findings": search_findings,
            "metadata": {
                "source_count": len(search_findings),
                "coverage": "high" if len(search_findings) >= 3 else "medium"
            }
        },
        "document_analysis_results": {
            "findings": analysis_findings,
            "metadata": {
                "documents_analyzed": len(set(
                    f.get("source", "") for f in analysis_findings
                )),
                "coverage": "medium"
            }
        }
    }
    return handoff



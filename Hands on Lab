    "src/utils/cache.py":
        "def get_cached(key): ...",
}


def grep_codebase(pattern):
    """Simulate Grep -- find files containing pattern."""
    matches = []
    for path, content in CODEBASE.items():
        if pattern.lower() in content.lower():
            # Find matching line
            for i, line in enumerate(
                content.split("\n"), 1
            ):
                if pattern.lower() in line.lower():
                    matches.append({
                        "file": path,
                        "line": i,
                        "content": line.strip(),
                    })
    return matches


def glob_codebase(pattern_suffix):
    """Simulate Glob -- find files by path pattern."""
    return [p for p in CODEBASE.keys()
            if p.endswith(pattern_suffix)]

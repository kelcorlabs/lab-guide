### Step 4: Add semantic validation

```python
# ============================================================
# PART 4: SEMANTIC VALIDATION
# ============================================================

def validate_extraction(data):
    """Validate semantic correctness.
    Schema catches syntax; this catches meaning.
    """
    errors = []

    # Cross-field check: line items vs total
    items = data.get("line_items", [])
    if items:
        calc = sum(i.get("amount", 0) for i in items)
        stated = data.get("total_amount")
        if stated and abs(calc - stated) > 0.01:
            if not data.get("conflict_detected"):
                errors.append(
                    f"Line items sum to ${calc:.2f} but "
                    f"total is ${stated:.2f}. "
                    f"conflict_detected should be true."
                )

    # Enum consistency check
    if (data.get("payment_status") == "other"
            and not data.get("payment_status_detail")):
        errors.append(
            "payment_status is 'other' but "
            "payment_status_detail is missing"
        )

    return errors

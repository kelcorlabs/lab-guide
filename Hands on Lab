    "delete_account", "modify_subscription", "issue_credit",
    "run_query", "generate_report", "export_data",
    "get_metrics", "create_dashboard", "schedule_job",
    "manage_users", "update_permissions", "audit_log",
]

AGENT_ROLES = {
    "support": {
        "description": "Customer inquiries and basic account operations",
        "tool_set": [
            "get_customer", "lookup_order", "process_refund",
            "escalate_to_human", "update_address",
        ],
    },
    "analytics": {
        "description": "Reports and business metrics",
        "tool_set": [
            "run_query", "generate_report", "export_data",
            "get_metrics", "create_dashboard",
        ],
    },
    "admin": {
        "description": "System administration and user management",
        "tool_set": [
            "manage_users", "update_permissions", "audit_log",
            "delete_account", "modify_subscription",
        ],
    },
}


def filter_tools_for_role(role_name):
    """Return only tools allowed for this role."""
    role = AGENT_ROLES.get(role_name)
    if not role:
        return {"error": f"Unknown role: {role_name}"}
    return role["tool_set"]


def attempt_tool_call(role_name, tool_name):
    """Check if a role is allowed to call a tool.
    Returns success or a structured access denial.
    """
    allowed = filter_tools_for_role(role_name)
    if isinstance(allowed, dict) and "error" in allowed:
        return allowed

    if tool_name in allowed:
        return {
            "allowed": True,
            "role": role_name,
            "tool": tool_name,
            "result": f"[Simulated] {tool_name} executed successfully"
        }

    return {
        "allowed": False,
        "role": role_name,
        "tool": tool_name,
        "error": f"Access denied: '{tool_name}' is not in "
                 f"{role_name}'s tool set",
        "available_tools": allowed,
    }



                 "delivery_eta", "delivery_attempts"},
    "billing": {"id", "total", "items", "customer_id",
                "created_at"},
}


def trim_tool_result(order, issue_type):
    """Keep only fields relevant to the issue type."""
    fields = TRIM_PROFILES.get(issue_type, set())
    return {k: v for k, v in order.items() if k in fields}

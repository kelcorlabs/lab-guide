                     "to parse)",
            "cmd": ‘claude -p "Review this PR" < /dev/null’,
        },
        {
            "label": "BETTER: JSON but no schema enforcement",
            "cmd": (‘claude -p "Review this PR" ‘
                    ‘--output-format json < /dev/null’),
        },
        {
            "label": "BEST: All flags for production CI",
            "cmd": (‘claude -p "Review this PR" ‘
                    ‘--output-format json ‘
                    ‘--json-schema review-schema.json ‘
                    ‘--allowedTools "Read,Grep,Glob" ‘
                    ‘< /dev/null’),
        },

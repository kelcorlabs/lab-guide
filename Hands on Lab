    "ORD-777": {"id": "ORD-777", "customer_id": "CUST-002",
                "total": 29.99, "status": "processing"}
}

# -- Gate state ---------------------------------------------
# This variable IS the gate. Only get_customer sets it.
# All other tools check it before executing.
verified_customer_id = None


def execute_tool(name, input_data):
    """Execute a tool with prerequisite gate enforcement."""
    global verified_customer_id

    if name == "get_customer":
        c = CUSTOMERS.get(input_data.get("email", ""))
        if c:
            verified_customer_id = c["id"]
            print(f"    [GATE] Customer verified: {verified_customer_id}")
            return json.dumps(c)
        return json.dumps({"error": "No customer found"})

    elif name == "lookup_order":
        # -- PREREQUISITE GATE --
        if verified_customer_id is None:
            print(f"    [BLOCKED] lookup_order requires get_customer first")
            return json.dumps({
                "isError": True,
                "errorCategory": "validation",
                "isRetryable": False,
                "message": "Customer verification required. "
                           "Call get_customer first."
            })
        o = ORDERS.get(input_data.get("order_id", ""))
        return json.dumps(o) if o else json.dumps({"error": "Order not found"})

    elif name == "process_refund":
        # -- PREREQUISITE GATE --
        if verified_customer_id is None:
            print(f"    [BLOCKED] process_refund requires get_customer first")
            return json.dumps({
                "isError": True,
                "errorCategory": "validation",
                "isRetryable": False,
                "message": "Customer verification required. "
                           "Call get_customer first."
            })
        amount = input_data.get("amount", 0)
        # -- POLICY GATE: $500 auto-approval limit --
        if amount > 500:
            print(f"    [BLOCKED] ${amount} exceeds $500 auto-approval limit")
            return json.dumps({
                "isError": True,
                "errorCategory": "business",
                "isRetryable": False,
                "message": f"Refund ${amount} exceeds $500 auto-approval limit.",
                "customer_friendly_message": (
                    "Your refund requires manager approval. "
                    "You'll hear back within 24 hours."
                )
            })
        return json.dumps({
            "success": True, "refund_amount": amount,
            "customer_id": verified_customer_id
        })

    elif name == "escalate_to_human":
        customer_id = input_data.get(
            "customer_id", verified_customer_id or "unknown"
        )
        print(f"    [ESCALATED] -> human agent")
        return json.dumps({
            "escalated": True, "ticket_id": "TKT-9999",
            "message": "Case transferred to human agent"
        })

    return json.dumps({"error": f"Unknown tool: {name}"})



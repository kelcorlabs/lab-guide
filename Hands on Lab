### Step 2: Implement multi-pass consensus filtering

```python
# ============================================================
# PART 2: MULTI-PASS CONSENSUS
# ============================================================

def consensus_filter(runs, min_agreement=2):
    """Report only findings found in min_agreement+ runs."""
    all_issues = []
    for run in runs:
        for f in run["findings"]:
            all_issues.append(f["issue"])

    counts = Counter(all_issues)
    consensus = [issue for issue, count in counts.items()
                 if count >= min_agreement]
    filtered = [issue for issue, count in counts.items()
                if count < min_agreement]

    return {
        "consensus_findings": consensus,
        "filtered_out": filtered,
        "counts": dict(counts),
    }
```


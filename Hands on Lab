def demo_transient_recovery():
    """
    Outcome 1: transient error on first attempt, success on retry.
    The coordinator is never involved -- resolved locally.
    """
    print("\n--- Outcome 1: Transient -> local retry -> success ---")
    max_retries = 1
    for attempt in range(max_retries + 1):
        # Simulate: first call times out, second call succeeds
        if attempt == 0:
            result = make_transient_error("get_customer")
            print(f"  attempt {attempt + 1}: "
                  f"{result['errorCategory']} -- retrying locally")

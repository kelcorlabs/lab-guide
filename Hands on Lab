            }
        },
        "document_analysis_results": {
            "findings": analysis_findings,
            "metadata": {
                "documents_analyzed": len(set(
                    f.get("source", "") for f in analysis_findings
                )),
                "coverage": "medium"
            }
        }
    }
    return handoff



### Step 4: Build the aggregated report structure

```python
# ============================================================
# PART 4: POSITION-AWARE REPORT STRUCTURE
# ============================================================

def build_report(findings):
    """Structure aggregated results to mitigate
    lost-in-the-middle effect.
    Summary at TOP (most reliable position).
    """
    summary_lines = []
    for f in findings:
        n = len(f["issues"])
        summary_lines.append(
            f"- {f['file']}: {n} issue(s)"
        )
    summary = ("KEY FINDINGS SUMMARY:\n"
               + "\n".join(summary_lines))

    details = []
    for f in findings:
        section = (f"\n--- FILE: {f['file']} "
                   f"({len(f['issues'])} issues) ---")
        for issue in f["issues"]:
            section += (
                f"\n  Line {issue['line']}: "
                f"[{issue['severity']}] "
                f"{issue['description']}"
            )
        details.append(section)

    return summary + "\n" + "\n".join(details)
```

### Step 5: Build the full context manager

```python
# ============================================================
# PART 5: CONTEXT MANAGER
# ============================================================

def manage_context(conversation, case_facts,
                   issue_type, max_turns=10):
    """Build a managed context with anchored facts,
    trimmed tool results, and summarized old turns.
    """
    # 1. Anchor case facts at the top
    context_parts = [build_case_facts(case_facts)]

    # 2. Keep only recent turns
    recent = conversation[-max_turns:]
    old = conversation[:-max_turns]

    # 3. Summarize old turns
    if old:
        resolved = [t for t in old
                    if t.get("resolved", False)]
        summary = (f"[{len(old)} earlier turns summarized: "
                   f"{len(resolved)} resolved points]")
        context_parts.append(summary)

    # 4. Add recent turns with trimmed tool results
    for turn in recent:
        content = turn["content"]
        if (turn["role"] == "tool_result"
                and isinstance(content, dict)):
            content = trim_tool_result(content, issue_type)
        context_parts.append(
            f"[Turn {turn['turn']}] "
            f"{turn['role']}: {content}"
        )

    return "\n\n".join(context_parts)
```


""".strip()


# -- SYNTHESIS PROMPT CONSTRUCTION -------------------------

def build_synthesis_prompt(handoff, topic):
    """Build a synthesis prompt that includes the full handoff.

    KEY: the synthesis agent receives ALL prior findings
    directly in its prompt. It has no other memory of what

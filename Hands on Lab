### Step 2: Build the ambiguity detector

```python
# ============================================================
# PART 2: AMBIGUITY DETECTION (deterministic rules)
# ============================================================

REQUIRED_FIELDS = {
    "refund": ["order_id", "reason"],
    "cancel": ["subscription_id"],
    "status": ["order_id"],
}


def detect_ambiguity(request_type, provided_fields,
                     match_count=1):
    """Score ambiguity using deterministic rules.
    NOT model self-reported confidence.
    """
    issues = []
    score = 0

    # Check 1: Missing required fields
    required = REQUIRED_FIELDS.get(request_type, [])
    for field in required:
        if field not in provided_fields:
            issues.append(
                f"Missing required field: {field}"
            )
            score += 2

    # Check 2: Multiple matches
    if match_count > 1:
        issues.append(
            f"Multiple matches: {match_count} records "
            f"found -- need disambiguation"
        )
        score += 3

    # Check 3: Vague references
    vague_terms = ["that thing", "my order",
                   "the item", "something"]
    for field, value in provided_fields.items():
        if isinstance(value, str):
            for vague in vague_terms:
                if vague in value.lower():
                    issues.append(
                        f"Vague reference in {field}: "
                        f"'{value}'"
                    )
                    score += 1

    return {
        "score": score,
        "issues": issues,
    }
```

### Step 3: Build the decision engine

```python
# ============================================================
# PART 3: DECISION ENGINE -- RESOLVE / CLARIFY / ESCALATE
# ============================================================

def decide_action(ambiguity_result, request_context):
    """Decide action based on ambiguity score and context.

    Returns: RESOLVE, CLARIFY, or ESCALATE with reason.
    """
    score = ambiguity_result["score"]
    issues = ambiguity_result["issues"]

    # Explicit human request -- always escalate
    if request_context.get("explicit_human_request"):
        return {
            "action": "ESCALATE",
            "reason": "Customer explicitly requested human",
            "trigger": "explicit_customer_request",
        }

    # Policy gap -- always escalate
    if request_context.get("policy_gap"):
        return {
            "action": "ESCALATE",
            "reason": "Policy is silent on this situation",
            "trigger": "policy_gap",
        }

    # No progress -- escalate after threshold
    attempts = request_context.get("tool_attempts", 0)
    if attempts >= 3:
        return {
            "action": "ESCALATE",
            "reason": "No progress after 3 attempts",
            "trigger": "no_progress",
        }

    # Ambiguity-based decisions
    if score == 0:
        return {
            "action": "RESOLVE",
            "reason": "All required info present, "
                      "no ambiguity",
        }

    if score <= 3:
        return {
            "action": "CLARIFY",
            "reason": "Ambiguous but resolvable with "
                      "more info",
            "questions": [
                f"Could you provide: "
                + ", ".join(
                    i.split(": ")[1]
                    for i in issues
                    if "Missing" in i
                )
            ] if any("Missing" in i for i in issues)
            else ["Could you be more specific?"],
        }

    return {
        "action": "ESCALATE",
        "reason": "High ambiguity -- too many unknowns "
                  "for safe resolution",
        "trigger": "high_ambiguity",
    }
```


## Reference code

This script simulates exactly what happens when Claude runs an agentic loop. It uses the same data structures, stop_reason values, and tool_result format as the real Claude API — so you can study the pattern and run it with just Python, no API key needed.

```python
import json

# ── Fake data (same as a real backend would have) ────────
CUSTOMERS = {
    "jane@email.com": {"id": "CUST-001", "name": "Jane Smith", "tier": "gold"},
    "bob@email.com":  {"id": "CUST-002", "name": "Bob Jones",  "tier": "silver"}
}
ORDERS = {
    "ORD-555": {"id": "ORD-555", "customer_id": "CUST-001",
                "items": ["Blue Widget x2"], "total": 149.99,
                "status": "shipped", "tracking": "1Z999AA10123456784"},
    "ORD-777": {"id": "ORD-777", "customer_id": "CUST-002",
                "items": ["Green Thing x1"], "total": 29.99,
                "status": "processing", "tracking": None}
}

def execute_tool(name, input_data):
    """Execute a tool and return the result as JSON (same as a real MCP tool)."""
    if name == "get_customer":
        c = CUSTOMERS.get(input_data.get("email", ""))
        return json.dumps(c) if c else json.dumps({"error": "No customer found"})
    if name == "lookup_order":
        o = ORDERS.get(input_data.get("order_id", ""))
        return json.dumps(o) if o else json.dumps({"error": "Order not found"})
    return json.dumps({"error": f"Unknown tool: {name}"})

# ── Tool definitions (these tell Claude what tools are available) ──
tools = [
    {
        "name": "get_customer",
        "description": (
            "Retrieves customer information by email address. "
            "Input: email (string). Returns: customer ID, name, tier. "
            "Use this to verify identity before any order operations."
        ),
        "input_schema": {"type": "object",
                         "properties": {"email": {"type": "string"}},
                         "required": ["email"]}
    },
    {
        "name": "lookup_order",
        "description": (
            "Retrieves order details by order ID (e.g. 'ORD-555'). "
            "Returns: status, items, total, tracking. "
            "Use when a customer asks about a specific order."
        ),
        "input_schema": {"type": "object",
                         "properties": {"order_id": {"type": "string"}},
                         "required": ["order_id"]}
    }
]

# ── Simulated Claude responses ───────────────────────────
# In production, these come from client.messages.create().
# Here we hardcode them to show the exact loop pattern.

def simulate_claude_responses(user_message):
    """
    Returns a list of simulated API responses showing the agentic loop.
    Each response has stop_reason and content — identical structure to real API.
    """
    if "jane@email.com" in user_message and "ORD-555" in user_message:
        return [
            # Iteration 1: Claude decides to look up the customer
            {
                "stop_reason": "tool_use",
                "content": [
                    {"type": "text", "text": "Let me look up your account first."},
                    {"type": "tool_use", "id": "call_001",
                     "name": "get_customer", "input": {"email": "jane@email.com"}}
                ]
            },
            # Iteration 2: Claude got customer, now looks up the order
            {
                "stop_reason": "tool_use",
                "content": [
                    {"type": "text", "text": "Found your account, Jane. Let me check that order."},
                    {"type": "tool_use", "id": "call_002",
                     "name": "lookup_order", "input": {"order_id": "ORD-555"}}
                ]
            },
            # Iteration 3: Claude has all info, responds to the user
            {
                "stop_reason": "end_turn",
                "content": [
                    {"type": "text", "text": "Hi Jane! Your order ORD-555 (Blue Widget x2, $149.99) "
                     "has been shipped. Tracking number: 1Z999AA10123456784."}
                ]
            }
        ]
    else:
        return [
            {
                "stop_reason": "tool_use",
                "content": [
                    {"type": "tool_use", "id": "call_010",
                     "name": "get_customer", "input": {"email": user_message.split()[0]}}
                ]
            },
            {
                "stop_reason": "end_turn",
                "content": [
                    {"type": "text", "text": "I couldn't find an account with that email. "
                     "Could you double-check your email address?"}
                ]
            }
        ]

# ── THE AGENTIC LOOP ─────────────────────────────────────
# This is the core pattern. Everything above is setup.
# In production, replace simulate_claude_responses() with
# client.messages.create() — the loop logic stays identical.

def run_agent(user_message):
    print(f"\n{'='*60}\nUSER: {user_message}\n{'='*60}\n")

    messages = [{"role": "user", "content": user_message}]
    responses = simulate_claude_responses(user_message)
    iteration = 0

    for response in responses:
        iteration += 1
        print(f"--- Loop iteration {iteration} ---")

        # ┌──────────────────────────────────────┐
        # │  stop_reason is the ONLY loop signal  │
        # └──────────────────────────────────────┘
        print(f"    stop_reason: {response['stop_reason']}")

        if response["stop_reason"] == "end_turn":
            # Done — extract final text and return
            text = " ".join(b["text"] for b in response["content"] if b.get("type") == "text")
            print(f"\nAGENT RESPONSE:\n{text}\n")
            return text

        elif response["stop_reason"] == "tool_use":
            # Not done — execute the tools Claude asked for
            messages.append({"role": "assistant", "content": response["content"]})

            tool_results = []
            for block in response["content"]:
                if block.get("type") == "tool_use":
                    print(f"    Tool call: {block['name']}({json.dumps(block['input'])})")
                    result = execute_tool(block["name"], block["input"])
                    print(f"    Result: {result[:80]}...")

                    # Tool results MUST be sent back as role "user"
                    tool_results.append({
                        "type": "tool_result",
                        "tool_use_id": block["id"],
                        "content": result
                    })

            # This line is critical — without it, Claude never gets the tool output
            messages.append({"role": "user", "content": tool_results})


if __name__ == "__main__":
    # Test 1: Known customer with known order (3 iterations)
    run_agent("I'm jane@email.com, can you check on my order ORD-555?")

    # Test 2: Unknown customer (2 iterations — fails at lookup)
    run_agent("unknown@email.com where's my order?")

    print("="*60)
    print("KEY EXAM CONCEPTS:")
    print("  - stop_reason 'tool_use' → execute tools, loop continues")
    print("  - stop_reason 'end_turn' → return response, loop terminates")
    print("  - Tool results MUST be appended as role 'user'")
    print("  - NEVER parse text to detect loop completion")
    print("="*60)
```


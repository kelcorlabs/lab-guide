### Step 5: Build the review queue with priority

```python
# ============================================================
# PART 5: PRIORITY REVIEW QUEUE
# ============================================================

def build_review_queue(applications):
    """Build priority-ordered review queue."""
    queue = []
    for app in applications:
        result = route_application(app)
        if result["action"] == "REVIEW":
            handoff = build_handoff(app, result)
            queue.append(handoff)

    # Sort by priority (highest first)
    queue.sort(key=lambda x: x["priority_score"],
               reverse=True)
    return queue
```


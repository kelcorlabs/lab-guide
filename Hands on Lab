### Step 2: Build deterministic routing rules

```python
# ============================================================
# PART 2: DETERMINISTIC ROUTING RULES
# ============================================================

ROUTING_RULES = {
    "high_amount": {
        "condition": "amount > 10000",
        "action": "REVIEW",
        "reason": "High-value application requires "
                  "human oversight",
    },
    "gray_zone_credit": {
        "condition": "credit_score between 580-620",
        "action": "REVIEW",
        "reason": "Credit score in gray zone -- "
                  "borderline approval/denial",
    },
    "missing_docs": {
        "condition": "income_verified is False",
        "action": "REVIEW",
        "reason": "Missing income verification -- "
                  "cannot auto-decide without docs",
    },
    "clear_denial": {
        "condition": "credit_score < 550",
        "action": "DENY",
        "reason": "Credit score below minimum "
                  "threshold",
    },
    "clear_approval": {
        "condition": "All criteria met, no flags",
        "action": "APPROVE",
        "reason": "All requirements clearly satisfied",
    },
}


def route_application(app):
    """Route using deterministic rules, NOT model
    confidence."""
    flags = []

    # Rule 1: High amount
    if app["amount"] > 10000:
        flags.append(("high_amount",
                       ROUTING_RULES["high_amount"]))

    # Rule 2: Gray zone credit
    if 580 <= app["credit_score"] <= 620:
        flags.append(("gray_zone_credit",
                       ROUTING_RULES["gray_zone_credit"]))

    # Rule 3: Missing documentation
    if not app["income_verified"]:
        flags.append(("missing_docs",
                       ROUTING_RULES["missing_docs"]))

    # Decision
    if flags:
        return {
            "action": "REVIEW",
            "flags": flags,
            "priority": len(flags) * app["amount"],
        }

    if app["credit_score"] < 550:
        return {
            "action": "DENY",
            "flags": [("clear_denial",
                        ROUTING_RULES["clear_denial"])],
            "priority": 0,
        }

    return {
        "action": "APPROVE",
        "flags": [("clear_approval",
                    ROUTING_RULES["clear_approval"])],
        "priority": 0,
    }
```


```python
import json

# -- Data layer (same structure as a real backend) ----------
CUSTOMERS = {
    "jane@email.com": {"id": "CUST-001", "name": "Jane Smith", "tier": "gold"},
    "bob@email.com":  {"id": "CUST-002", "name": "Bob Jones",  "tier": "silver"}
}
ORDERS = {
    "ORD-555": {"id": "ORD-555", "customer_id": "CUST-001",
                "items": ["Blue Widget x2"], "total": 149.99,
                "status": "shipped", "tracking": "1Z999AA10123456784"},
    "ORD-777": {"id": "ORD-777", "customer_id": "CUST-002",
                "items": ["Green Thing x1"], "total": 29.99,
                "status": "processing", "tracking": None}
}


def execute_tool(name, input_data):
    """Execute a tool and return the result as JSON."""
    if name == "get_customer":
        c = CUSTOMERS.get(input_data.get("email", ""))
        return json.dumps(c) if c else json.dumps({"error": "No customer found"})
    if name == "lookup_order":
        o = ORDERS.get(input_data.get("order_id", ""))
        return json.dumps(o) if o else json.dumps({"error": "Order not found"})
    return json.dumps({"error": f"Unknown tool: {name}"})


# -- Tool definitions (sent to Claude with each request) ----
tools = [
    {
        "name": "get_customer",
        "description": (
            "Retrieves customer information by email address. "
            "Input: email (string). Returns: customer ID, name, tier. "
            "Use this to verify identity before any order operations."
        ),
        "input_schema": {
            "type": "object",
            "properties": {"email": {"type": "string"}},
            "required": ["email"]
        }
    },
    {
        "name": "lookup_order",
        "description": (
            "Retrieves order details by order ID (e.g. 'ORD-555'). "
            "Returns: status, items, total, tracking. "
            "Use when a customer asks about a specific order."
        ),
        "input_schema": {
            "type": "object",
            "properties": {"order_id": {"type": "string"}},
            "required": ["order_id"]
        }
    }
]


# -- Simulated Claude responses -----------------------------
# In production, each iteration calls client.messages.create().
# Here we pre-build the response sequence so you can study the
# loop pattern without an API key.

def simulate_claude_responses(user_message):
    """Return the sequence of responses Claude would send."""
    if "jane@email.com" in user_message and "ORD-555" in user_message:
        return [
            # Iteration 1: Claude decides to look up the customer
            {
                "stop_reason": "tool_use",
                "content": [
                    {"type": "text", "text": "Let me look up your account first."},
                    {"type": "tool_use", "id": "call_001",
                     "name": "get_customer", "input": {"email": "jane@email.com"}}
                ]
            },
            # Iteration 2: Got customer, now looks up the order
            {
                "stop_reason": "tool_use",
                "content": [
                    {"type": "text", "text": "Found your account, Jane. Let me check that order."},
                    {"type": "tool_use", "id": "call_002",
                     "name": "lookup_order", "input": {"order_id": "ORD-555"}}
                ]
            },
            # Iteration 3: Has all info, delivers final answer
            {
                "stop_reason": "end_turn",
                "content": [
                    {"type": "text", "text": "Hi Jane! Your order ORD-555 (Blue Widget x2, "
                     "$149.99) has been shipped. Tracking: 1Z999AA10123456784."}
                ]
            }
        ]
    else:
        return [
            # Iteration 1: Tries to look up the customer
            {
                "stop_reason": "tool_use",
                "content": [
                    {"type": "tool_use", "id": "call_010",
                     "name": "get_customer",
                     "input": {"email": user_message.split()[0]}}
                ]
            },
            # Iteration 2: Customer not found, tells the user
            {
                "stop_reason": "end_turn",
                "content": [
                    {"type": "text", "text": "I couldn't find an account with that email. "
                     "Could you double-check your email address?"}
                ]
            }
        ]


# -- THE AGENTIC LOOP ---------------------------------------
# This is the core pattern. Everything above is setup.
# In production, replace the 2-line simulation block with:
#   response = client.messages.create(
#       model="claude-sonnet-4-20250514", messages=messages,
#       tools=tools, max_tokens=1024
#   )

def run_agent(user_message):
    print(f"\n{'='*60}")
    print(f"USER: {user_message}")
    print(f"{'='*60}\n")

    messages = [{"role": "user", "content": user_message}]
    response_queue = simulate_claude_responses(user_message)
    response_index = 0
    iteration = 0
    pending_tool_ids = []

    while True:
        # -- Simulate API validation -------------------------
        # The real Anthropic API rejects the request if the
        # previous turn had tool_use blocks but the next
        # message doesn't include matching tool_results.
        if pending_tool_ids:
            last_msg = messages[-1] if messages else {}
            provided_ids = set()
            if (last_msg.get("role") == "user"
                    and isinstance(last_msg.get("content"), list)):
                provided_ids = {
                    b.get("tool_use_id") for b in last_msg["content"]
                    if b.get("type") == "tool_result"
                }
            missing = [tid for tid in pending_tool_ids
                       if tid not in provided_ids]
            if missing:
                raise RuntimeError(
                    f"API Error: every tool_use block needs a matching "
                    f"tool_result in the next message. Missing "
                    f"tool_result for: {', '.join(missing)}"
                )
            pending_tool_ids = []

        # -- In production, this is your API call --------
        response = response_queue[response_index]
        response_index += 1
        iteration += 1

        print(f"--- Iteration {iteration} ---")
        print(f"    stop_reason: {response['stop_reason']}")

        # +------------------------------------------+
        # |  stop_reason is the ONLY loop signal     |
        # +------------------------------------------+

        if response["stop_reason"] == "end_turn":
            # Done -- extract final text and exit the loop
            final_text = " ".join(
                b["text"] for b in response["content"]
                if b.get("type") == "text"
            )
            print(f"\nFINAL RESPONSE:\n{final_text}\n")
            return final_text

        if response["stop_reason"] == "tool_use":
            # Not done -- execute tools and send results back
            messages.append({"role": "assistant", "content": response["content"]})

            # Track which tool_use IDs need matching tool_results
            pending_tool_ids = [
                b["id"] for b in response["content"]
                if b.get("type") == "tool_use"
            ]

            tool_results = []
            for block in response["content"]:
                if block.get("type") == "tool_use":
                    print(f"    Tool call: {block['name']}({json.dumps(block['input'])})")
                    result = execute_tool(block["name"], block["input"])
                    print(f"    Result: {result[:80]}...")
                    tool_results.append({
                        "type": "tool_result",
                        "tool_use_id": block["id"],
                        "content": result
                    })

            # CRITICAL: tool results must go back as role "user"
            messages.append({"role": "user", "content": tool_results})


if __name__ == "__main__":
    # Test 1: Known customer with known order (expect 3 iterations)
    run_agent("I'm jane@email.com, can you check on my order ORD-555?")

    # Test 2: Unknown customer (expect 2 iterations)
    run_agent("unknown@email.com where's my order?")
```


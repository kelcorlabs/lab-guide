    "errorCategory": "business",      # Policy violation, not a technical failure
    "isRetryable": False,              # Don't try again with the same amount
    "message": "Refund $750 exceeds $500 auto-approval limit.",
    "customer_friendly_message": "Your refund requires manager approval..."

def make_empty_result(query):
    """
    isError: False -- the tool succeeded. There is just no data.
    This is NOT an error. The database query ran cleanly; it found
    no customer with this email. Without this distinction, Claude
    says "something went wrong" when it should say "no account found."
    """
    return {
        "isError": False,
        "results": None,
        "message": f"No records found for '{query}'",
        "query_executed": query

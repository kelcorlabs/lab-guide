```python
import json

# -- THE PROBLEM -----------------------------------------------
# A generic error string gives Claude nothing to act on:
#     {"error": "Operation failed"}
#
# Claude cannot answer:
#   Retry?      Unknown -- could be transient or permanent
#   Fix input?  Unknown -- could be bad data or a system crash
#   Tell user?  Unknown -- could be an error or just no record
#
# Structured errors give Claude the category and isRetryable flag
# it needs to make an intelligent recovery decision.

# -- FOUR ERROR CATEGORY HELPERS --------------------------------

def make_transient_error(operation):
    """Timeout or temporary unavailability -- may work if retried."""
    return {
        "isError": True,
        "errorCategory": "transient",
        "isRetryable": True,
        "message": f"{operation} timed out after 5 seconds",
        "attempted_query": operation,
        "suggestion": "Retry in a few seconds -- temporary service issue"
    }

def make_validation_error(field, issue):
    """Bad input from the model -- retrying with same input will not help."""
    return {
        "isError": True,
        "errorCategory": "validation",
        "isRetryable": False,
        "message": f"Invalid {field}: {issue}",
        "fix_hint": f"Correct the {field} before retrying"
    }

def make_business_error(message, customer_message):
    """Policy violation -- not a system error, a business rule."""
    return {
        "isError": True,
        "errorCategory": "business",
        "isRetryable": False,
        "message": message,
        "customer_friendly_message": customer_message
    }

def make_permission_error(resource):
    """Access denied -- agent lacks rights to this resource."""
    return {
        "isError": True,
        "errorCategory": "permission",
        "isRetryable": False,
        "message": f"Access denied to {resource}",
        "escalation_required": True
    }
```


def rank_sources(findings):
    """Rank findings by source reliability tier."""
    ranked = []
    for f in findings:
        source = SOURCES[f["source_id"]]
        ranked.append({
            **f,
            "source_name": source["name"],
            "source_tier": source["tier"],
            "source_type": source["type"],
        })
    ranked.sort(key=lambda x: x["source_tier"])
    return ranked
```

### Step 3: Build the conflict detector

```python
# ============================================================
# PART 3: CONFLICT DETECTION
# ============================================================

def detect_conflicts(findings):
    """Find claims about the same topic from different
    sources with different values."""
    # Group by topic (simplified: check for overlapping
    # key terms)
    topics = {}
    for f in findings:
        # Extract topic key from claim
        claim = f["claim"].lower()
        if "enterprise" in claim and "cost" in claim:
            key = "enterprise_pricing"
        elif "rate limit" in claim:
            key = "api_rate_limit"
        else:
            key = f["claim"][:30]

        topics.setdefault(key, []).append(f)

    conflicts = []
    for topic, claims in topics.items():
        if len(claims) > 1:
            # Check if values actually differ
            values = set(c["claim"] for c in claims)
            if len(values) > 1:
                conflicts.append({
                    "topic": topic,
                    "claims": claims,
                    "source_count": len(claims),
                })

    return conflicts
```

### Step 4: Build the provenance-preserving synthesizer

```python
# ============================================================
# PART 4: SYNTHESIS WITH PROVENANCE
# ============================================================

def synthesize_with_provenance(findings):
    """Synthesize findings preserving all provenance."""
    ranked = rank_sources(findings)
    conflicts = detect_conflicts(findings)

    output = {
        "synthesis": [],
        "conflicts": [],
        "source_summary": {},
    }

    # Build sourced claims
    for f in ranked:
        output["synthesis"].append({
            "claim": f["claim"],
            "source": f["source_name"],
            "source_tier": f["source_tier"],
            "publication_date": f["publication_date"],
            "excerpt": f["excerpt"],
        })

    # Annotate conflicts
    for conflict in conflicts:
        sources = []
        for c in conflict["claims"]:
            src = SOURCES[c["source_id"]]
            sources.append({
                "claim": c["claim"],
                "source": src["name"],
                "tier": src["tier"],
                "date": c["publication_date"],
            })

        # Sort by tier (most authoritative first)
        sources.sort(key=lambda x: x["tier"])

        resolution = ""
        dates = [s["date"] for s in sources]
        if len(set(dates)) > 1:
            resolution = (
                "Temporal difference: sources from "
                "different dates. Prefer most recent "
                "authoritative source."
            )
        else:
            resolution = (
                "Same-date conflict: may reflect "
                "different tiers/methodologies. "
                "Flag for human review."
            )

        output["conflicts"].append({
            "topic": conflict["topic"],
            "sources": sources,
            "resolution_note": resolution,
            "recommended_value": sources[0]["claim"],
            "recommended_source": sources[0]["source"],
        })

    # Source summary
    for sid, src in SOURCES.items():
        used = [f for f in findings
                if f["source_id"] == sid]
        output["source_summary"][src["name"]] = {
            "tier": src["tier"],
            "type": src["type"],
            "claims_used": len(used),
            "last_updated": src["last_updated"],
        }

    return output
```


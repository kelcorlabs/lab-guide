# ============================================================

def validate_ci_command(command):
    """Check a claude CLI command for common CI mistakes."""
    print(f"\n  Command: {command[:70]}...")
    issues = []

    # Check 1: Missing -p flag
    if " -p " not in command and not command.startswith("claude -p"):
        issues.append(
            "MISSING -p FLAG -- job will hang in CI "
            "waiting for interactive input"
        )

    # Check 2: No --output-format json
    if "--output-format json" not in command:
        issues.append(
            "No --output-format json -- output will be "
            "prose, hard to parse in automation"
        )

    # Check 3: --output-format json without --json-schema
    if ("--output-format json" in command
            and "--json-schema" not in command):
        issues.append(
            "Has --output-format json but no "
            "--json-schema -- output structure not "
            "guaranteed between runs"
        )

    # Check 4: No stdin redirect
    if "< /dev/null" not in command:
        issues.append(
            "No < /dev/null -- may read from stdin "
            "in some CI environments"
        )

    # Check 5: Unrestricted Bash in review context
    if ("review" in command.lower()
            and "--allowedTools" not in command):
        issues.append(
            "Review command without --allowedTools -- "
            "Claude Code has unrestricted Bash access "
            "on CI runner"
        )

    if issues:
        for issue in issues:
            print(f"    [WARNING] {issue}")
    else:
        print(f"    [OK] All CI checks pass")

    return issues



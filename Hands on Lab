# ============================================================
# PART 3: CATEGORY DISABLE/ENABLE (TRUST RESTORATION)
# ============================================================

def build_criteria(enabled, disabled):
    """Build review criteria with category control."""
    criteria = "REPORT these issue types:\n"
    for cat in enabled:
        criteria += (f"- {cat.replace('_', ' ').title()}: "
                     f"flag when found\n")
    if disabled:
        criteria += ("\nDO NOT REPORT (temporarily disabled "
                     "for improvement):\n")
        for cat in disabled:
            criteria += (f"- {cat.replace('_', ' ').title()}: "
                         f"SKIP\n")
    return criteria
```

### Step 4: Add the criteria scoring function

```python
# ============================================================
# PART 4: CRITERIA VALIDATOR (scores a prompt)
# ============================================================

CRITERIA_CHECKLIST = {
    "specific_categories": "Defines specific issue categories",
    "negative_examples": "Specifies what NOT to flag",
    "comment_rule": "Has a rule for when comments are wrong",
    "format_spec": "Defines output format (JSON, fields)",
    "severity_levels": "Defines severity criteria",
}


def score_criteria(prompt_text):
    """Score a review prompt against the FP checklist."""
    p = prompt_text.lower()
    scores = {}

    scores["specific_categories"] = (
        1 if any(w in p for w in
                 ["sql injection", "hardcoded", "security",
                  "bug", "exception"]) else 0
    )
    scores["negative_examples"] = (
        1 if any(w in p for w in
                 ["do not report", "do not flag", "skip",
                  "not a bug"]) else 0
    )
    scores["comment_rule"] = (
        1 if "contradict" in p or "contradicts" in p else 0
    )
    scores["format_spec"] = (
        1 if "json" in p or "return" in p else 0
    )
    scores["severity_levels"] = (
        1 if "high" in p and ("low" in p or "medium" in p)
        else 0
    )

    return scores
```

